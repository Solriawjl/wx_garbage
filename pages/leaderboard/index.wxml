<view class="leaderboard-page">
  <view class="header-banner">
    <text class="banner-title">知识挑战积分榜</text>
    <text class="banner-desc">每天参与分类与挑战，争夺环保之巅！</text>
  </view>

  <view class="list-container">
    <block wx:for="{{leaderboardList}}" wx:key="user_id">
      <view class="list-item">
        <view class="rank-box">
          <text wx:if="{{item.rank === 1}}" class="medal gold">🥇</text>
          <text wx:elif="{{item.rank === 2}}" class="medal silver">🥈</text>
          <text wx:elif="{{item.rank === 3}}" class="medal bronze">🥉</text>
          <text wx:else class="rank-num">{{item.rank}}</text>
        </view>
        
        <image class="user-avatar" src="{{item.avatar_url}}" mode="aspectFill"></image>
        <view class="user-info">
          <text class="user-name">{{item.nickname}}</text>
          <text class="user-title {{item.titleClass}}">{{item.title}}</text>
        </view>
        
        <view class="score-box">
          <text class="score-num score-rank-{{item.rank <= 3 ? item.rank : 'other'}}">{{item.total_score}}</text>
          <text class="score-label">分</text>
        </view>
      </view>
    </block>
  </view>
</view>