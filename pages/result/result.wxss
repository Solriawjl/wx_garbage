/* pages/result/result.wxss */
.result-page {
  padding: 40rpx 30rpx;
  background-color: #f4faeb; /* 换成和首页一致的浅绿底色，减少大面积白色的空洞感 */
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* --- 核心识别结果卡片 --- */
.result-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-top: 80rpx; 
  padding-bottom: 40rpx;
  position: relative; 
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #e0e0e0; 
  position: absolute; 
  top: -80rpx; 
  box-shadow: 0 6rpx 15rpx rgba(0,0,0,0.15);
}

.result-text-box {
  margin-top: 100rpx; 
  font-size: 38rpx;
  text-align: center;
}

.item-name {
  color: #333333;
  font-weight: bold;
}

.static-text {
  color: #666666;
  font-size: 32rpx;
  margin: 0 10rpx;
}

.category-name {
  font-weight: bold;
  font-size: 40rpx;
}

/* 动态控制垃圾类型的颜色 */
.recycle { color: #2e7d32; } /* 可回收 - 绿色 */
.harmful { color: #c62828; } /* 有害 - 红色 */
.kitchen { color: #d7fa26; } /* 厨余 - 黄色 */
.other { color: #424242; }   /* 其他 - 灰色 */

/* 存放标签的弹性容器，让标签居中显示 */
.tag-container {
  margin-top: 25rpx;
  display: flex;
  justify-content: center;
}

/* 词库精准匹配标签 (浅绿色，给人一种100%正确的安全感) */
.match-tag {
  background-color: #e8f5e9;
  color: #4CAF50;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  display: inline-flex;
  align-items: center;
  font-weight: bold;
}

/* AI 识别置信度标签 (极简灰，具有科技感) */
.confidence-tag {
  background-color: #f5f5f5;
  color: #888;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  display: inline-flex;
  align-items: center;
}

/* 图标的微调 */
.icon-check, .icon-ai {
  margin-right: 10rpx;
  font-size: 26rpx;
}

/* 知识库同款精美卡片样式 */
  .desc-card {
  width: 95%;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-top: 30rpx;
  box-sizing: border-box;
}

.desc-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
}

.desc-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
}

/* 半透明分割线 */
.desc-divider {
  width: 100%;
  height: 2rpx;
  opacity: 0.15;
  margin: 30rpx 0;
}

.tip-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

/* --- 四大类动态主题配色 --- */

/* 可回收物 (蓝色系) */
.desc-card.recycle { background-color: #e3efff; }
.desc-card.recycle .desc-divider { background-color: #4c84ff; }
.desc-card.recycle .tip-title { color: #7ca2f2; }

/* 厨余垃圾 (绿色系) */
.desc-card.kitchen { background-color: #e5f8cf; }
.desc-card.kitchen .desc-divider { background-color: #8bc34a; }
.desc-card.kitchen .tip-title { color: #8bc34a; }

/* 其他垃圾 (橙色/黄色系) */
.desc-card.other { background-color: #fff8e1; }
.desc-card.other .desc-divider { background-color: #ffb300; }
.desc-card.other .tip-title { color: #ffb300; }

/* 有害垃圾 (红色系) */
.desc-card.harmful { background-color: #ffebee; }
.desc-card.harmful .desc-divider { background-color: #e53935; }
.desc-card.harmful .tip-title { color: #e53935; }

/* ==========================================
   新增与优化专属样式
   ========================================== */

/* --- 明确目标垃圾桶提示区 --- */
.target-bin {
  font-size: 28rpx;
  color: #444;
  background-color: rgba(255, 255, 255, 0.7);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 2rpx 10rpx rgba(0,0,0,0.02);
}

.target-bin-icon {
  font-size: 38rpx;
  margin-right: 12rpx;
}

.bin-name {
  font-size: 32rpx;
  font-weight: bold;
  margin: 0 4rpx;
}

/* 匹配四大类的文字颜色 */
.bin-name.recycle { color: #4c84ff; }
.bin-name.kitchen { color: #8bc34a; }
.bin-name.other { color: #ffb300; }
.bin-name.harmful { color: #e53935; }

/* --- 猜你想扔 (横向滚动区域) --- */
.recommend-section {
  width: 95%;
  margin-top: 20rpx;
}

.recommend-title {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
  margin-bottom: 20rpx;
  padding-left: 10rpx;
}

.recommend-scroll {
  width: 100%;
  white-space: nowrap; 
  display: flex;
}

.recommend-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 160rpx;
  margin-right: 25rpx;
  background-color: #fff;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.05);
  flex-shrink: 0; 
}

.recommend-item:first-child { margin-left: 5rpx; }

.rec-image {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background-color: #f5f5f5;
  margin-bottom: 15rpx;
}

.rec-name {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  width: 100%;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
}

/* ==========================================
   ✨ 全新吸底悬浮操作栏 (Bottom Dock)
   ========================================== */
.bottom-dock {
  position: fixed;
  bottom: 0;
  left: 0;
  width: 100%;
  height: 140rpx;
  background-color: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px); /* 磨砂玻璃效果 */
  box-shadow: 0 -4rpx 30rpx rgba(0,0,0,0.08);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 30rpx;
  padding-bottom: env(safe-area-inset-bottom); /* 适配苹果刘海屏底部小黑条 */
  box-sizing: border-box;
  z-index: 100;
}

.dock-btn {
  display: flex;
  align-items: center;
  justify-content: center;
}

.dock-btn.icon-btn {
  flex-direction: column;
  width: 110rpx;
  height: 100%;
}

.dock-icon {
  font-size: 40rpx;
  margin-bottom: 6rpx;
  color: #555;
}

.dock-text {
  font-size: 20rpx;
  color: #666;
  font-weight: 500;
}

.dock-btn.primary-btn {
  width: 420rpx;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.15);
  transition: all 0.2s;
}

.dock-btn.primary-btn:active {
  transform: scale(0.96); /* 点击时的微小缩放动效 */
}

.dock-btn-icon {
  font-size: 36rpx;
  margin-right: 10rpx;
}

/* 按钮主题色动态匹配当前垃圾分类 */
.dock-btn.primary-btn.recycle { background-color: #4c84ff; box-shadow: 0 6rpx 16rpx rgba(76, 132, 255, 0.3); }
.dock-btn.primary-btn.kitchen { background-color: #8bc34a; box-shadow: 0 6rpx 16rpx rgba(139, 195, 74, 0.3); }
.dock-btn.primary-btn.other { background-color: #ffb300; box-shadow: 0 6rpx 16rpx rgba(255, 179, 0, 0.3); }
.dock-btn.primary-btn.harmful { background-color: #e53935; box-shadow: 0 6rpx 16rpx rgba(229, 57, 53, 0.3); }


/* --- 专属提示弹窗 (Modal) --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background-color: rgba(0,0,0,0.6);
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.modal-content {
  width: 75%;
  background-color: #fff;
  border-radius: 24rpx;
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.2);
}

.modal-header {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.modal-body {
  font-size: 30rpx;
  line-height: 1.6;
  color: #444;
  text-align: center;
  margin-bottom: 40rpx;
}

.modal-btn {
  width: 80%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  background-color: #4CAF50;
  color: #fff;
  border-radius: 40rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.modal-content.recycle .modal-btn { background-color: #4c84ff; }
.modal-content.harmful .modal-btn { background-color: #e53935; }
.modal-content.kitchen .modal-btn { background-color: #8bc34a; }
.modal-content.other .modal-btn { background-color: #ffb300; }

/* 小类指导的引导标题 */
.sub-guide-title {
  font-size: 26rpx;
  color: #333;
  font-weight: bold;
  margin-top: 25rpx;
  margin-bottom: 10rpx;
  padding-left: 5rpx;
}

/* ==========================================
   ✨ 中间区域 UI 终极优化升级
   ========================================== */

/* 强制让科普卡片回归纯白，增强呼吸感和整洁度 */
.desc-card.white-card {
  background-color: #ffffff !important;
  box-shadow: 0 8rpx 24rpx rgba(0,0,0,0.06); /* 增加柔和的悬浮阴影 */
  border: none;
  margin-top: 24rpx;
}

/* --- 核心指示牌：目标垃圾桶 (超强视觉焦点) --- */
.target-bin-banner {
  width: 95%;
  margin: 30rpx auto 10rpx auto;
  border-radius: 20rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 10rpx 30rpx rgba(0,0,0,0.15);
}

/* 四大类专属高亮渐变色 (让指示牌极具质感) */
.target-bin-banner.recycle-bg { background: linear-gradient(135deg, #4c84ff, #2962ff); }
.target-bin-banner.kitchen-bg { background: linear-gradient(135deg, #8bc34a, #558b2f); }
.target-bin-banner.harmful-bg { background: linear-gradient(135deg, #e53935, #b71c1c); }
.target-bin-banner.other-bg { background: linear-gradient(135deg, #ffb300, #f39c12); }

.bin-action { 
  font-size: 28rpx; 
  opacity: 0.9; 
  margin-bottom: 8rpx; 
}

.bin-name-large { 
  font-size: 52rpx; 
  font-weight: bold; 
  letter-spacing: 4rpx;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2); /* 文字投影，增加立体感 */
}

/* --- 细分小类指导：做成侧边带颜色的引用框，打破枯燥 --- */
.sub-guidance-box {
  margin-top: 15rpx;
  padding: 20rpx 24rpx;
  background-color: #f8f9fa; /* 极浅的灰色底 */
  border-radius: 12rpx;
  border-left: 8rpx solid #ccc; /* 默认左边框 */
}

/* 引用框左边框跟随大类变色 */
.sub-guidance-box.recycle-border { border-left-color: #4c84ff; }
.sub-guidance-box.kitchen-border { border-left-color: #8bc34a; }
.sub-guidance-box.harmful-border { border-left-color: #e53935; }
.sub-guidance-box.other-border { border-left-color: #ffb300; }

/* 覆盖之前可能存在的旧样式，让文字换行更好看 */
.sub-guidance-text {
  font-size: 26rpx;
  line-height: 1.8;
  color: #555;
  background-color: transparent; 
  padding: 0;
}

/* 单独让特定科普标题带点颜色 */
.tip-title.recycle-text { color: #2e7d32; }
.tip-title.harmful-text { color: #c62828; }

/* =========================================
   每日任务环保星掉落动画样式 (全新：右侧边界滑入版)
   ========================================= */
   .reward-popup-container {
    position: fixed;
    /* 调整高度，大概在胶囊按钮的下方或平齐，避开刘海屏 */
    top: 120rpx; 
    /* 初始位置完全藏在屏幕右侧边界外面 (-100%) */
    right: -100%; 
    left: auto; /* 清除居中逻辑 */
    width: auto; /* 宽度随内容 */
    pointer-events: none; /* 防止遮挡点击 */
    z-index: 99999;
    opacity: 0;
    
    /* 绑定新的横向滑入动画，时间依然是我们刚才调好的 4 秒 */
    animation: slideInFromRight 4s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
  }
  
  /* 将卡片设计改为了“游戏 UI 风格”，像从屏幕边缘长出来一样 */
  .reward-card {
    display: flex;
    align-items: center;
    background: linear-gradient(135deg, #FFF9C4 0%, #FFD54F 100%);
    /* 减小内边距，使其更小巧 */
    padding: 12rpx 30rpx;
    /* 去掉右侧圆角 (左侧圆角，右侧直角) */
    border-radius: 40rpx 0rpx 0rpx 40rpx; 
    /* 去掉右侧边框，使其与边界无缝融合 */
    border: 4rpx solid #FFF59D;
    border-right: none; 
    /* 阴影只需向左和向下投射 */
    box-shadow: -4rpx 8rpx 20rpx rgba(255, 152, 0, 0.2); 
  }
  
  .coin-icon {
    width: 50rpx; /* 稍微缩小图标 */
    height: 50rpx;
    margin-right: 16rpx;
  }
  
  .reward-text-group {
    display: flex;
    flex-direction: column;
  }
  
  .reward-title {
    font-size: 20rpx; /* 字体缩小，更适合右上角 */
    color: #F57F17;
    font-weight: bold;
  }
  
  .reward-score {
    font-size: 32rpx; /* 字体缩小，更适合右上角 */
    color: #E65100;
    font-weight: 900;
    text-shadow: 0 2rpx 4rpx rgba(255,255,255,0.5);
  }
  
  /* 向左横向滑入并停留 */
  @keyframes slideInFromRight {
    0% {
      right: -100%; /* off-screen right */
      opacity: 0;
      transform: scale(0.9); /* 开始时稍微小一点点 */
    }
    10% { /* 0.4秒内迅速滑入 */
      right: 0rpx; /* 滑入到完全靠在右侧边界 (0rpx) */
      opacity: 1;
      transform: scale(1);
    }
    /* 从 10% 到 90% (约 3.2 秒)，稳稳停靠在右侧边界 */
    90% {
      right: 0rpx;
      top: 120rpx;
      opacity: 1;
      transform: scale(1);
    }
    /* 缓缓向右上角透明消失 */
    100% {
      right: -20rpx; /* 往右侧边界外面稍微移一点 */
      top: 80rpx; /* 缓缓上浮 */
      opacity: 0; 
      transform: scale(0.9);
    }
  }