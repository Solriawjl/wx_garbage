/* pages/result/result.wxss */
.result-page {
  padding: 40rpx 30rpx;
  background-color: #f4faeb; /* 换成和首页一致的浅绿底色，减少大面积白色的空洞感 */
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* --- 核心识别结果卡片 --- */
.result-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-top: 80rpx; 
  padding-bottom: 40rpx;
  position: relative; 
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #e0e0e0; 
  position: absolute; 
  top: -80rpx; 
  box-shadow: 0 6rpx 15rpx rgba(0,0,0,0.15);
}

.result-text-box {
  margin-top: 100rpx; 
  font-size: 38rpx;
  text-align: center;
}

.item-name {
  color: #333333;
  font-weight: bold;
}

.static-text {
  color: #666666;
  font-size: 32rpx;
  margin: 0 10rpx;
}

.category-name {
  font-weight: bold;
  font-size: 40rpx;
}

/* 动态控制垃圾类型的颜色 */
.recycle { color: #2e7d32; } /* 可回收 - 绿色 */
.harmful { color: #c62828; } /* 有害 - 红色 */
.kitchen { color: #d7fa26; } /* 厨余 - 黄色 */
.other { color: #424242; }   /* 其他 - 灰色 */

/* 置信度标签 */
.accuracy-tag {
  margin-top: 20rpx;
  background-color: #f5f5f5;
  color: #a5a5a5;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
}

/* --- 资讯卡片通用样式 --- */
.info-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-top: 30rpx;
  padding: 30rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

/* 投放指导卡片加一点特殊背景色突出 */
.highlight-card {
  background-color: #fffde7; /* 浅黄色背景 */
  border: 2rpx dashed #ffb300;
}

.info-title {
  font-size: 30rpx;
  color: #333333;
  font-weight: bold;
  margin-bottom: 15rpx;
}

.info-content {
  font-size: 26rpx;
  color: #666666;
  line-height: 1.6;
}

/* --- 底部控制区 (打包沉底) --- */
.bottom-controls {
  width: 100%;
  margin-top: auto; /* 将整个控制区推到屏幕最下方 */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx; /* 距离屏幕最底部的安全距离 */
}

/* --- 重播语音按钮 --- */
.voice-section {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx; /* 控制它和下面两个按钮之间固定、紧凑的间距 */
}

.voice-btn {
  width: 130rpx;
  height: 130rpx;
  background-color: #8bc34a; 
  border-radius: 50%; 
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(139, 195, 74, 0.4);
}

/* --- 底部操作按钮组 --- */
.action-group {
  width: 100%;
  display: flex;
  justify-content: space-between;
  /* 移除了原来的 margin-top: auto 和 padding-top */
}

.btn {
  width: 46%;
  height: 88rpx;
  border-radius: 44rpx; 
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.research-btn { background-color: #64b5f6; }
.feedback-btn { background-color: #e57373; }