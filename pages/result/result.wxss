/* pages/result/result.wxss */
.result-page {
  padding: 40rpx 30rpx;
  background-color: #f4faeb; /* 换成和首页一致的浅绿底色，减少大面积白色的空洞感 */
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* --- 核心识别结果卡片 --- */
.result-card {
  width: 100%;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin-top: 80rpx; 
  padding-bottom: 40rpx;
  position: relative; 
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.05);
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #e0e0e0; 
  position: absolute; 
  top: -80rpx; 
  box-shadow: 0 6rpx 15rpx rgba(0,0,0,0.15);
}

.result-text-box {
  margin-top: 100rpx; 
  font-size: 38rpx;
  text-align: center;
}

.item-name {
  color: #333333;
  font-weight: bold;
}

.static-text {
  color: #666666;
  font-size: 32rpx;
  margin: 0 10rpx;
}

.category-name {
  font-weight: bold;
  font-size: 40rpx;
}

/* 动态控制垃圾类型的颜色 */
.recycle { color: #2e7d32; } /* 可回收 - 绿色 */
.harmful { color: #c62828; } /* 有害 - 红色 */
.kitchen { color: #d7fa26; } /* 厨余 - 黄色 */
.other { color: #424242; }   /* 其他 - 灰色 */

/* 存放标签的弹性容器，让标签居中显示 */
.tag-container {
  margin-top: 25rpx;
  display: flex;
  justify-content: center;
}

/* 词库精准匹配标签 (浅绿色，给人一种100%正确的安全感) */
.match-tag {
  background-color: #e8f5e9;
  color: #4CAF50;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  display: inline-flex;
  align-items: center;
  font-weight: bold;
}

/* AI 识别置信度标签 (极简灰，具有科技感) */
.confidence-tag {
  background-color: #f5f5f5;
  color: #888;
  font-size: 24rpx;
  padding: 8rpx 24rpx;
  border-radius: 30rpx;
  display: inline-flex;
  align-items: center;
}

/* 图标的微调 */
.icon-check, .icon-ai {
  margin-right: 10rpx;
  font-size: 26rpx;
}

/* 知识库同款精美卡片样式 */
  .desc-card {
  width: 95%;
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-top: 30rpx;
  box-sizing: border-box;
}

.desc-title {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
}

.desc-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
}

/* 半透明分割线 */
.desc-divider {
  width: 100%;
  height: 2rpx;
  opacity: 0.15;
  margin: 30rpx 0;
}

.tip-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
}

/* --- 四大类动态主题配色 --- */

/* 可回收物 (蓝色系) */
.desc-card.recycle { background-color: #e3efff; }
.desc-card.recycle .desc-divider { background-color: #4c84ff; }
.desc-card.recycle .tip-title { color: #7ca2f2; }

/* 厨余垃圾 (绿色系) */
.desc-card.kitchen { background-color: #e5f8cf; }
.desc-card.kitchen .desc-divider { background-color: #8bc34a; }
.desc-card.kitchen .tip-title { color: #8bc34a; }

/* 其他垃圾 (橙色/黄色系) */
.desc-card.other { background-color: #fff8e1; }
.desc-card.other .desc-divider { background-color: #ffb300; }
.desc-card.other .tip-title { color: #ffb300; }

/* 有害垃圾 (红色系) */
.desc-card.harmful { background-color: #ffebee; }
.desc-card.harmful .desc-divider { background-color: #e53935; }
.desc-card.harmful .tip-title { color: #e53935; }

/* --- 底部控制区 (打包沉底) --- */
.bottom-controls {
  width: 100%;
  margin-top: auto; /* 将整个控制区推到屏幕最下方 */
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-bottom: 60rpx; /* 距离屏幕最底部的安全距离 */
}

/* --- 重播语音按钮 --- */
.voice-section {
  display: flex;
  justify-content: center;
  margin-bottom: 60rpx; /* 控制它和下面两个按钮之间固定、紧凑的间距 */
}

.voice-btn {
  width: 130rpx;
  height: 130rpx;
  background-color: #8bc34a; 
  border-radius: 50%; 
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  box-shadow: 0 8rpx 20rpx rgba(139, 195, 74, 0.4);
}

/* --- 底部操作按钮组 --- */
.action-group {
  width: 100%;
  display: flex;
  justify-content: space-between;
  /* 移除了原来的 margin-top: auto 和 padding-top */
}

.btn {
  width: 46%;
  height: 88rpx;
  border-radius: 44rpx; 
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 30rpx;
  color: #ffffff;
  font-weight: 500;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.research-btn { background-color: #64b5f6; }
.feedback-btn { background-color: #e57373; }