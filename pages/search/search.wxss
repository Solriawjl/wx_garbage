/* pages/search/search.wxss */
.search-page {
  padding: 30rpx;
  background-color: #ffffff;
  min-height: 100vh;
}

/* --- 搜索框区域 --- */
.search-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 50rpx;
}

.search-input-group {
  flex: 1;
  background-color: #f2f2f2; /* 浅灰色背景 */
  height: 80rpx;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  padding: 0 25rpx;
  margin-right: 30rpx;
}

.input-element {
  flex: 1;
  margin-left: 15rpx;
  font-size: 28rpx;
}

.placeholder-style {
  color: #b2b2b2;
}

.search-confirm-btn {
  color: #4c84ff; /* 原型图中的蓝色 */
  font-size: 32rpx;
  font-weight: 500;
}

/* --- 历史搜索标题栏 --- */
.history-title-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.title-text {
  font-size: 28rpx;
  color: #666;
}

.delete-icon {
  width: 40rpx;
  height: 40rpx;
}

/* --- 标签云布局 --- */
.tag-container {
  display: flex;
  flex-wrap: wrap; /* 自动换行 */
  gap: 20rpx; /* 标签之间的间距 */
}

.tag-item {
  background-color: #b0b8c4; /* 蓝灰色背景 */
  color: #ffffff;
  padding: 12rpx 40rpx;
  border-radius: 40rpx; /* 全圆角胶囊形状 */
  font-size: 28rpx;
  min-width: 80rpx;
  text-align: center;
}