/* pages/search/index.wxss */
.search-page {
  min-height: 100vh;
  background-color: #ffffff;
}

/* 顶部搜索栏 */
.search-header {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background-color: #4CAF50; /* 保持跟首页一致的主题绿 */
}

.search-bar {
  flex: 1;
  background-color: #ffffff;
  height: 70rpx;
  border-radius: 35rpx;
  display: flex;
  align-items: center;
  padding: 0 25rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 15rpx;
  color: #333;
}

.cancel-btn {
  font-size: 30rpx;
  color: #ffffff;
  margin-left: 30rpx;
}

/* 内容区 */
.content-body {
  padding: 40rpx 30rpx;
}

.section {
  margin-bottom: 50rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 25rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.delete-icon, .hot-icon {
  font-size: 30rpx;
  color: #999;
  padding: 10rpx; /* 增加点击热区 */
}

/* 标签容器 */
.tags-container {
  display: flex;
  flex-wrap: wrap;
}

.tag {
  background-color: #f5f5f5;
  color: #555;
  font-size: 26rpx;
  padding: 12rpx 30rpx;
  border-radius: 30rpx;
  margin-right: 20rpx;
  margin-bottom: 20rpx;
}

/* 热门标签可以加点特殊的底色 */
.hot-tag {
  background-color: #e8f5e9;
  color: #2e7d32;
}

/* --- 🚀 搜索联想列表样式 --- */
.suggest-list {
  background-color: #ffffff;
  padding: 0 30rpx;
}

.suggest-item {
  display: flex;
  align-items: center;
  padding: 30rpx 10rpx;
  border-bottom: 2rpx solid #f5f5f5;
}

.suggest-item:active {
  background-color: #f9f9f9; /* 点击时的反馈效果 */
}

.suggest-item:last-child {
  border-bottom: none;
}

.suggest-text {
  font-size: 30rpx;
  color: #333;
  margin-left: 20rpx;
}