<view class="result-page">

<view class="achievement-card" style="background: {{titleColor}};">
  <view class="badge-bg"></view>
  <view class="achievement-content">
    <image class="trophy-icon" src="/images/tab_quiz_active.png" mode="aspectFit"></image>
    <view class="title-text">{{performance}}</view>
    <view class="score-badge">
      <text class="score-plus">+</text>
      <text class="score-value">{{currentScore}}</text>
      <text class="score-unit"> 颗环保星</text>
    </view>
  </view>
</view>

<view class="review-card">
  <view class="card-title">答题复盘</view>
  
  <block wx:if="{{wrongList.length > 0}}">
    <view class="review-subtitle">本次错题（点击查看图文科普）</view>
    <block wx:for="{{wrongList}}" wx:key="index">
      <view class="review-item clickable" bindtap="goToSearchDetail" data-keyword="{{item.name}}">
        <view class="item-name">{{item.name}}</view>
        
        <view class="item-answers">
          <text class="wrong-ans">{{item.userSelect}}</text>
          <text class="correct-ans">{{item.correctAnswer}}</text>
        </view>
        <view class="arrow-right">></view>
      </view>
    </block>
  </block>
  
  <view class="perfect-state" wx:else>
    <icon type="success" size="60" color="#4CAF50"></icon>
    <view class="perfect-text">太棒了！全部答对！</view>
  </view>
</view>

<view class="action-group">
    <view class="btn retry-btn" bindtap="handleLeftBtn">再来一局</view>
    <view class="btn share-btn" bindtap="handleRightBtn">返回首页</view>
</view>

</view>