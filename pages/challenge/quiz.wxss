/* pages/challenge/quiz.wxss */
.quiz-page {
  min-height: 100vh;
  background-color: #f4faeb; /* 护眼浅绿底色 */
  padding: 40rpx 30rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

/* --- 进度条 --- */
.progress-section {
  margin-bottom: 60rpx;
}

.progress-text {
  text-align: right;
  margin-bottom: 10rpx;
  font-size: 32rpx;
  color: #666;
  font-weight: bold;
}

.progress-text .current {
  color: #4CAF50;
  font-size: 40rpx;
}

.progress-bar-bg {
  width: 100%;
  height: 16rpx;
  background-color: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
}

.progress-bar-fill {
  height: 100%;
  background-color: #4CAF50;
  border-radius: 8rpx;
  transition: width 0.4s ease; /* 进度条滑动的动画 */
}

/* --- 题目区 --- */
.question-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 80rpx;
  background-color: #fff;
  padding: 80rpx 40rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.03);
}

.question-item {
  font-size: 60rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
  text-align: center;
}

.question-desc {
  font-size: 28rpx;
  color: #999;
}

/* --- 选项网格区 --- */
.options-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 30rpx 0; /* 控制行间距 */
}

.option-card {
  width: 47%;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 40rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.04);
  border: 4rpx solid transparent; /* 预留边框位置，防止闪烁 */
  transition: all 0.2s;
}

/* 点击时的按压效果 */
.option-card:active {
  transform: scale(0.96);
}

.option-icon {
  width: 100rpx;
  height: 120rpx;
  margin-bottom: 15rpx;
}

.option-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* --- 状态样式 (重点：即时反馈的颜色) --- */
.option-card.correct {
  border-color: #4CAF50;
  background-color: #e8f5e9;
}

.option-card.wrong {
  border-color: #F44336;
  background-color: #ffebee;
}

/* 答题期间禁用其他选项点击 */
.option-card.disabled {
  pointer-events: none; 
}

.status-icon {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
}

/* 题目图片样式 */
.question-image {
  width: 240rpx;
  height: 240rpx;
  border-radius: 20rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.08);
  background-color: #f5f7fa; /* 图片加载前的底色 */
}

.timer-bar {
  text-align: center;
  font-size: 36rpx;
  font-weight: bold;
  color: #FF9800;
  margin-bottom: 20rpx;
  transition: color 0.3s;
}
.timer-danger {
  color: #F44336;
  animation: heartbeat 1s infinite; /* 心跳动画制造紧张感 */
}
@keyframes heartbeat {
  0% { transform: scale(1); }
  50% { transform: scale(1.1); }
  100% { transform: scale(1); }
}