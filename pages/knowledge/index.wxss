/* pages/knowledge/index.wxss */
.knowledge-page {
  min-height: 100vh;
  background-color: #f8f8f8;
}

/* --- 顶部 Tab 样式 --- */
.tab-header {
  display: flex;
  background-color: #ffffff;
  position: relative;
  height: 90rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
}

.tab-item {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  color: #666;
  font-weight: 500;
  transition: all 0.3s;
}

.tab-item.active {
  color: #4CAF50;
  font-weight: bold;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  width: 20%; 
  height: 6rpx;
  background-color: #4CAF50;
  border-radius: 6rpx;
  transition: left 0.3s ease; 
}

.tab-content {
  padding: 30rpx;
}

/* --- 图谱：顶部垃圾桶导航 --- */
.category-nav {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  opacity: 0.6;
  transition: all 0.2s;
}

.nav-item.nav-active {
  opacity: 1;
  transform: scale(1.1);
}

.bin-icon {
  width: 100rpx;
  height: 120rpx;
  border-radius: 12rpx 12rpx 20rpx 20rpx;
  margin-bottom: 10rpx;
}

.nav-item text {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

/* --- 图谱：整合版描述与指导卡片 --- */
.desc-card {
  border-radius: 20rpx;
  padding: 40rpx 30rpx;
  margin-bottom: 40rpx;
  color: #333;
}

.desc-title {
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.desc-text {
  font-size: 28rpx;
  line-height: 1.6;
  color: #444;
}

/* 优雅的半透明分割线 */
.desc-divider {
  width: 100%;
  height: 2rpx;
  opacity: 0.15; 
  margin: 30rpx 0;
}

.tip-title {
  font-size: 30rpx;
  font-weight: bold;
  margin-bottom: 15rpx;
  color: #333;
}

/* --- 图谱：平铺的百科字典样式 --- */
.dict-container {
  padding-bottom: 40rpx; 
}

.dict-group {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); 
}

.dict-group-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
  border-bottom: 2rpx solid #f9f9f9;
  padding-bottom: 20rpx;
}

.title-line {
  width: 8rpx;
  height: 30rpx;
  border-radius: 4rpx;
  margin-right: 15rpx;
}

.dict-item-list {
  display: flex;
  flex-wrap: wrap;
}

.dict-item {
  width: 50%; /* 一行放两列 */
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-right: 15rpx;
  opacity: 0.8;
}

.item-name {
  font-size: 28rpx;
  color: #444;
}

/* --- 小知识：文章列表 --- */
.article-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.03);
}

.article-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding-right: 20rpx;
}

.article-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-desc {
  font-size: 26rpx;
  color: #999;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.article-date {
  font-size: 24rpx;
  color: #ccc;
  margin-top: 10rpx;
}

.article-img {
  width: 180rpx;
  height: 140rpx;
  border-radius: 12rpx;
  background-color: #e0e0e0;
}

/* 让日期和阅读量左右分布 */
.article-meta {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 15rpx;
}

.article-views {
  font-size: 24rpx;
  color: #ff9800; /* 火苗橙色 */
}

/* 分页加载提示文本 */
.loading-box, .no-more, .empty-state {
  text-align: center;
  font-size: 24rpx;
  color: #bbb;
  padding: 30rpx 0;
}