<view class="login-container">
  
  <view class="header-section">
    <image class="logo" src="/images/login.png" mode="aspectFill"></image>
    <view class="title">智分小卫士</view>
    <view class="subtitle">选择你的专属身份，开启环保之旅！</view>
  </view>
  
  <view class="role-section">
    <view class="role-card student-card" hover-class="card-hover" bindtap="selectStudent">
      <view class="card-left">
        <view class="icon-bg">🌱</view>
      </view>
      <view class="card-middle">
        <view class="role-name">环保小卫士</view>
        <view class="role-desc">我是学生或家长</view>
      </view>
      <view class="card-right">
        <view class="arrow">进入 ❯</view>
      </view>
    </view>
    
    <view class="role-card teacher-card" hover-class="card-hover" bindtap="selectTeacher">
      <view class="card-left">
        <view class="icon-bg teacher-icon-bg">👩‍🏫</view>
      </view>
      <view class="card-middle">
        <view class="role-name">指导老师</view>
        <view class="role-desc">需专属邀请码验证</view>
      </view>
      <view class="card-right">
        <view class="arrow">验证 ❯</view>
      </view>
    </view>
  </view>

  <view class="footer-section">
    <view class="tips">微信将安全授权并与该身份绑定</view>
  </view>

  <view class="modal-mask" wx:if="{{showRegisterModal}}">
    <view class="modal-content">
      <view class="modal-title">{{registerRole === 'teacher' ? '教师身份注册' : '新生入学登记'}}</view>
      <view class="modal-subtitle">请选择您所属的年级与班级，开启数据大盘！</view>
      
      <view class="picker-container">
        <text class="picker-label">所属班级：</text>
        <picker mode="multiSelector" class="class-picker" bindchange="onPickerChange" bindcolumnchange="onPickerColumnChange" value="{{pickerIndex}}" range="{{pickerArray}}">
          <view class="picker-value">
            {{pickerArray[0][pickerIndex[0]]}} {{pickerArray[1][pickerIndex[1]]}} ▾
          </view>
        </picker>
      </view>

      <input wx:if="{{registerRole === 'teacher'}}" class="modal-input" placeholder="请输入学校分配的教师邀请码" placeholder-class="input-placeholder" bindinput="inputInviteCode" value="{{inviteCode}}"/>
      
      <view class="modal-btns">
        <view class="btn cancel-btn" bindtap="cancelRegister">取消</view>
        <view class="btn confirm-btn" bindtap="confirmRegister">确定入驻</view>
      </view>
    </view>
  </view>

</view>