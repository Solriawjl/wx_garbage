<view class="history-page">

<view class="filter-bar" wx:if="{{historyList.length > 0}}">
  <text class="filter-text">共 {{historyList.length}} 条记录</text>
  <view class="clear-btn" bindtap="clearAll">
    <text class="icon-trash">🗑️</text> 一键清空
  </view>
</view>

<scroll-view scroll-y="true" class="list-container" bindtap="recoverSwipe">
  
  <block wx:if="{{historyList.length > 0}}">
    <view class="list-item-wrap" wx:for="{{historyList}}" wx:key="id">
      
      <view class="challenge-card" bindtap="goToDetail" data-item="{{item}}"
            bindtouchstart="touchS" bindtouchmove="touchM" bindtouchend="touchE" data-index="{{index}}"
            style="transform: translateX({{item.offsetX || 0}}rpx); transition: {{isMoving ? 'none' : 'transform 0.3s'}};">
        
        <view class="remove-btn" catchtap="removeItem" data-index="{{index}}">✕</view>

        <view class="card-header">
          <view class="score-box">
            <text class="score-label">获得积分</text>
            <text class="score-num">+{{item.score}}</text>
          </view>
          <view class="title-tag {{item.titleClass}}">{{item.title}}</view>
        </view>
        
        <view class="card-divider"></view>
        
        <view class="card-footer">
          <view class="stat-box">
            <text class="stat-label">答题正确率：</text>
            <text class="stat-val {{item.correctCount === 10 ? 'perfect' : ''}}">{{item.correctCount}} / 10</text>
          </view>
          
          <view class="date-box">
            <text class="date-text">{{item.date}}</text>
            </view>
        </view>
        
      </view>

      <view class="delete-action" catchtap="removeItem" data-index="{{index}}">删除</view>

    </view>
  </block>

  <view class="empty-state" wx:else>
    <icon type="info" size="64" color="#ccc"></icon>
    <text class="empty-text">暂无挑战记录，快去证明你的实力吧！</text>
  </view>

</scroll-view>

</view>