<view class="container" wx:if="{{reportData}}">
  
  <view class="card header-card">
    <view class="user-info">
      <view class="title-box">
        <text class="level-badge">{{reportData.basic_info.current_title}}</text>
        <text class="beat-text">击败了全校 {{reportData.basic_info.beat_percentage}}% 的同学！</text>
      </view>
    </view>
    <view class="data-row">
      <view class="data-item">
        <text class="num highlight">{{reportData.basic_info.total_stars}}</text>
        <text class="label">总环保星</text>
      </view>
      <view class="data-item">
        <text class="num">{{reportData.learning_habit.recognize_count}}</text>
        <text class="label">实拍次数</text>
      </view>
      <view class="data-item">
        <text class="num">{{reportData.learning_habit.quiz_count}}</text>
        <text class="label">答题次数</text>
      </view>
    </view>
  </view>

  <view class="card chart-card">
    <view class="card-title">✨ 四维环保能力矩阵</view>
    <view class="chart-container">
      <ec-canvas id="mychart-dom-radar" canvas-id="mychart-radar" ec="{{ ecRadar }}" force-use-old-canvas="{{false}}"></ec-canvas>
    </view>
  </view>

  <view class="card chart-card">
    <view class="card-title">📈 近7天学习打卡走势</view>
    <view class="chart-container">
      <ec-canvas id="mychart-dom-line" canvas-id="mychart-line" ec="{{ ecLine }}"></ec-canvas>
    </view>
  </view>

  <view class="card chart-card">
    <view class="card-title">🧬 学习行为偏好基因</view>
    <view class="chart-container">
      <ec-canvas id="mychart-dom-habit" canvas-id="mychart-habit" ec="{{ ecHabit }}"></ec-canvas>
    </view>
  </view>

  <view class="card chart-card" wx:if="{{reportData.mistake_analysis.total_wrong > 0}}">
    <view class="card-title">🎯 错题深度剖析与歼灭战况</view>
    
    <view class="progress-box">
      <view class="progress-labels">
        <text class="label-left">已消灭：{{reportData.mistake_analysis.cleared_count}} 题</text>
        <text class="label-right">总错题：{{reportData.mistake_analysis.total_wrong}} 题</text>
      </view>
      <view class="progress-bar-bg">
        <view class="progress-bar-fill" style="width: {{reportData.mistake_analysis.clear_rate * 100 + '%'}}"></view>
      </view>
      <text class="progress-tip">目前错题消化率达到 {{reportData.mistake_analysis.clear_rate * 100 + '%'}}</text>
    </view>

    <view class="chart-container" style="height: 400rpx;">
      <ec-canvas id="mychart-dom-mistake" canvas-id="mychart-mistake" ec="{{ ecMistake }}"></ec-canvas>
    </view>
  </view>

  <view class="card summary-card">
    <view class="card-title">💡 综合学情诊断</view>
    <view class="tag-row">
      <view class="tag style-1">称号：{{reportData.learning_habit.preference_tag}}</view>
      <view class="tag style-2">消化率：{{reportData.mistake_analysis.clear_rate * 100 + '%'}}</view>
    </view>
    <view class="ai-comment">
      <text class="comment-icon">🤖</text>
      <text class="comment-text">{{reportData.ai_comment}}</text>
    </view>
  </view>

</view> <view class="loading-state" wx:else>
  <text>正在生成专属多维成长报告...</text>
</view>