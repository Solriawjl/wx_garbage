<view class="history-page">

<view class="filter-bar" wx:if="{{hasData}}">
  <text class="filter-text">共 {{historyList.length}} 条</text>
  
  <picker bindchange="onFilterChange" value="{{filterIndex}}" range="{{filterOptions}}">
    <view class="filter-picker">
      <text>{{filterOptions[filterIndex]}}</text>
      <text class="picker-arrow">▼</text>
    </view>
  </picker>

  <view class="clear-btn" bindtap="clearAll">
    <text class="icon-trash">🗑️</text> 一键清空
  </view>
</view>

<scroll-view scroll-y="true" class="list-container" bindtap="recoverSwipe">
  
  <block wx:if="{{historyList.length > 0}}">
    <view class="list-item-wrap" wx:for="{{historyList}}" wx:key="id">
      
      <view class="history-card" bindtap="goToDetail" data-item="{{item}}"
            bindtouchstart="touchS" bindtouchmove="touchM" bindtouchend="touchE" data-index="{{index}}"
            style="transform: translateX({{item.offsetX || 0}}rpx); transition: {{isMoving ? 'none' : 'transform 0.3s'}};">
        
        <view class="remove-btn" catchtap="removeItem" data-index="{{index}}">✕</view>

        <image class="item-img" src="{{item.imageUrl}}" mode="aspectFill"></image>
        
        <view class="item-info">
          <view class="info-top">
            <text class="item-name">{{item.itemName}}</text>
          </view>
          
          <view class="tag {{item.categoryClass}}">{{item.categoryName}}</view>
          
          <view class="item-date">{{item.date}}</view>
        </view>
        
      </view>

      <view class="delete-action" catchtap="removeItem" data-index="{{index}}">删除</view>
    </view>
  </block>

  <view class="empty-state" wx:else>
    <icon type="info" size="64" color="#ccc"></icon>
    <text class="empty-text">暂无对应分类的识别记录~</text>
  </view>

</scroll-view>

<view class="modal-mask" wx:if="{{showDetailModal}}" bindtap="closeDetail">
  <view class="detail-card" catchtap="preventTouch">
    <image class="detail-img" src="{{currentDetailItem.imageUrl}}" mode="aspectFill"></image>
    
    <view class="detail-info">
      <view class="detail-title">AI 识别结果</view>
      <view class="detail-name">{{currentDetailItem.itemName}}</view>
      
      <view class="detail-tags">
        <view class="tag {{currentDetailItem.categoryClass}}">{{currentDetailItem.categoryName}}</view>
        <view class="confidence-tag" wx:if="{{currentDetailItem.confidence}}">置信度：{{currentDetailItem.confidence}}%</view>
      </view>
      
      <view class="detail-date">识别时间：{{currentDetailItem.date}}</view>
    </view>
    
    <view class="modal-actions">
      <view class="action-btn cancel-btn" bindtap="closeDetail">我知道了</view>
      <view class="action-btn feedback-btn" bindtap="goToFeedback">识别有误？去反馈</view>
    </view>
  </view>
</view>

</view>