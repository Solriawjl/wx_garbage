<view class="history-page">

<view class="nav-bar">
  <view class="nav-item {{currentTab === 0 ? 'active' : ''}}" bindtap="switchTab" data-index="0">待核销</view>
  <view class="nav-item {{currentTab === 1 ? 'active' : ''}}" bindtap="switchTab" data-index="1">已核销</view>
  <view class="nav-item {{currentTab === 2 ? 'active' : ''}}" bindtap="switchTab" data-index="2">已退回</view>
</view>

<view class="empty-state" wx:if="{{filteredList.length === 0}}">
  <text class="empty-icon">🎁</text>
  <text class="empty-text">当前分类下没有记录哦~</text>
</view>

<view class="record-list" wx:else>
  <view class="record-card" wx:for="{{filteredList}}" wx:key="id">
    
    <view class="card-body">
      <image class="item-img" src="{{item.imageUrl}}" mode="aspectFit"></image>
      
      <view class="item-info">
        <view class="info-top">
          <text class="item-name">{{item.itemName}}</text>
          <view class="status-tag {{item.status === 0 ? 'pending' : (item.status === 1 ? 'finished' : 'cancelled')}}">
            {{item.status === 0 ? '待核销' : (item.status === 1 ? '已核销' : '已退货')}}
          </view>
        </view>
        
        <view class="info-bottom">
          <text class="item-time">{{item.date}}</text>
          <text class="item-cost {{item.status === 2 ? 'cancelled-cost' : ''}}">
            {{item.status === 2 ? '退回 ' : '-'}}{{item.pointsCost}} 小红花
          </text>
        </view>
      </view>
    </view>

    <view class="card-footer" wx:if="{{item.status === 0}}">
      <view class="action-btn refund-btn" 
            bindtap="handleRefund" 
            data-id="{{item.id}}" 
            data-name="{{item.itemName}}"
            data-points="{{item.pointsCost}}">
        我反悔了，申请退货
      </view>
    </view>

  </view>
</view>
</view>