/* pages/user/recognizeHistory.wxss */
.history-page {
  min-height: 100vh;
  background-color: #f5f7fa; /* 极浅灰底色 */
  display: flex;
  flex-direction: column;
}

/* --- 筛选栏 --- */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.filter-text {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.filter-btn {
  font-size: 28rpx;
  color: #4CAF50;
  display: flex;
  align-items: center;
}

.icon-filter {
  font-size: 24rpx; 
  margin-left: 8rpx;
  font-family: Arial, sans-serif;
}

/* --- 列表容器 --- */
.list-container {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* --- 历史记录卡片 (左图右文设计) --- */
.history-card {
  display: flex;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03);
  transition: transform 0.1s;
}

.history-card:active {
  transform: scale(0.98); /* 点击反馈 */
}

/* 左侧图片 */
.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #e0e0e0;
  margin-right: 30rpx;
  flex-shrink: 0;
}

/* 右侧信息区 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.arrow {
  color: #ccc;
  font-family: consolas;
}

/* 分类小标签通用样式 */
.tag {
  align-self: flex-start;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  margin-top: 10rpx;
}

/* 四大类动态颜色配置 */
.tag.recycle { background-color: #e3efff; color: #4c84ff; }
.tag.kitchen { background-color: #f1f8e9; color: #68b644; }
.tag.harmful { background-color: #ffebee; color: #e53935; }
.tag.other { background-color: #fff8e1; color: #ffb300; }

.item-date {
  font-size: 24rpx;
  color: #999;
  text-align: right; /* 时间靠右对齐 */
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* --- 弹窗详情卡片样式 --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.65); /* 稍微加深遮罩背景 */
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.detail-card {
  width: 82%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden; /* 保证顶部的图片也能有圆角 */
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: popIn 0.3s ease-out forwards;
}

@keyframes popIn {
  0% { transform: scale(0.85); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.detail-img {
  width: 100%;
  height: 380rpx;
  background-color: #f0f0f0; 
}

.detail-info {
  padding: 40rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.detail-title {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.detail-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
}

/* 标签容器 */
.detail-tags {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx; /* 标签之间的间距 */
}

/* 置信度专属小标签 */
.confidence-tag {
  font-size: 24rpx;
  background-color: #f5f5f5;
  color: #888;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  margin-top: 10rpx; /* 对齐前面的分类tag */
}

.detail-date {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 40rpx;
}

/* --- 底部双按钮排版 (经典 iOS 风格) --- */
.modal-actions {
  display: flex;
  width: 100%;
  border-top: 2rpx solid #f0f0f0;
  height: 96rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  transition: background-color 0.1s;
}

.action-btn:active {
  background-color: #f9f9f9;
}

.cancel-btn {
  color: #666;
  border-right: 2rpx solid #f0f0f0;
}

.feedback-btn {
  color: #F44336; /* 用红色警示色突出纠错功能 */
}