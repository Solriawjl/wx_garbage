/* pages/user/recognizeHistory.wxss */
.history-page {
  min-height: 100vh;
  background-color: #f5f7fa; /* 极浅灰底色 */
  display: flex;
  flex-direction: column;
}

/* --- 筛选栏 --- */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.filter-text {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.filter-btn {
  font-size: 28rpx;
  color: #4CAF50;
  display: flex;
  align-items: center;
}

.icon-filter {
  font-size: 24rpx; 
  margin-left: 8rpx;
  font-family: Arial, sans-serif;
}

/* --- 🚀 新增：中间下拉筛选器样式 --- */
.filter-picker {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  border: 2rpx solid #eeeeee;
  transition: all 0.2s;
}

.filter-picker:active {
  background-color: #e0e0e0;
}

.picker-arrow {
  font-size: 18rpx;
  margin-left: 10rpx;
  color: #888;
}

/* --- 覆盖顶栏的清空按钮样式 --- */
.clear-btn {
  font-size: 26rpx;
  color: #F44336;
  display: flex;
  align-items: center;
  padding: 7rpx 20rpx;
  background-color: #ffebee;
  border-radius: 30rpx;
  transition: transform 0.1s;
}
.clear-btn:active { transform: scale(0.95); }
.icon-trash { margin-right: 8rpx; font-size: 26rpx; }

/* --- 列表容器 --- */
.list-container {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* --- 左滑删除核心样式 --- */

/* 1. 外层包裹器：接管阴影和整体间距，彻底消除红边溢出 */
.list-item-wrap {
  position: relative;
  width: 100%;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  background-color: #ffffff; /* 改回白色底，彻底消灭红色边框伪影 */
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); /* 阴影放在外层，防止滑动时被裁切断裂 */
}

/* 2. 可滑动的卡片本体 (左图右文设计) */
.history-card {
  display: flex;
  margin-bottom: 0 !important;
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 2; /* 盖在删除按钮上面 */
  background-color: #ffffff; 
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: none !important; /* 去除内部阴影，由外层包裹器接管 */
  transition: transform 0.1s;
}

.history-card:active {
  transform: scale(0.98); /* 点击反馈 */
}

/* 3. 右上角独立删除 X (弱化颜色，让页面更干净协调) */
.remove-btn {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  color: #d8d8d8; /* 颜色调浅一点，不抢视觉焦点 */
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: consolas;
  font-size: 32rpx;
  z-index: 10;
}

/* 4. 底层露出的删除按钮 */
.delete-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #FF5252; /* 🚀 将红色背景移到这里，并换成质感更好的西瓜红 */
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  z-index: 1;
  /* 完美贴合外层卡片的右侧圆角 */
  border-top-right-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}

/* 左侧图片 */
.item-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  background-color: #e0e0e0;
  margin-right: 30rpx;
  flex-shrink: 0;
}

/* 右侧信息区 */
.item-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.info-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.item-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.arrow {
  color: #ccc;
  font-family: consolas;
}

/* 分类小标签通用样式 */
.tag {
  align-self: flex-start;
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  margin-top: 10rpx;
}

/* 四大类动态颜色配置 */
.tag.recycle { background-color: #e3efff; color: #4c84ff; }
.tag.kitchen { background-color: #f1f8e9; color: #68b644; }
.tag.harmful { background-color: #ffebee; color: #e53935; }
.tag.other { background-color: #fff8e1; color: #ffb300; }

.item-date {
  font-size: 24rpx;
  color: #999;
  text-align: right; /* 时间靠右对齐 */
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* --- 弹窗详情卡片样式 --- */
.modal-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.65); /* 稍微加深遮罩背景 */
  z-index: 999;
  display: flex;
  justify-content: center;
  align-items: center;
}

.detail-card {
  width: 82%;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden; /* 保证顶部的图片也能有圆角 */
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: popIn 0.3s ease-out forwards;
}

@keyframes popIn {
  0% { transform: scale(0.85); opacity: 0; }
  100% { transform: scale(1); opacity: 1; }
}

.detail-img {
  width: 100%;
  height: 380rpx;
  background-color: #f0f0f0; 
}

.detail-info {
  padding: 40rpx 30rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  box-sizing: border-box;
}

.detail-title {
  font-size: 26rpx;
  color: #888;
  margin-bottom: 12rpx;
}

.detail-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
}

/* 标签容器 */
.detail-tags {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 20rpx; /* 标签之间的间距 */
}

/* 置信度专属小标签 */
.confidence-tag {
  font-size: 24rpx;
  background-color: #f5f5f5;
  color: #888;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-weight: 500;
  margin-top: 10rpx; /* 对齐前面的分类tag */
}

.detail-date {
  font-size: 24rpx;
  color: #aaa;
  margin-top: 40rpx;
}

/* --- 底部双按钮排版 (经典 iOS 风格) --- */
.modal-actions {
  display: flex;
  width: 100%;
  border-top: 2rpx solid #f0f0f0;
  height: 96rpx;
}

.action-btn {
  flex: 1;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  transition: background-color 0.1s;
}

.action-btn:active {
  background-color: #f9f9f9;
}

.cancel-btn {
  color: #666;
  border-right: 2rpx solid #f0f0f0;
}

.feedback-btn {
  color: #F44336; /* 用红色警示色突出纠错功能 */
}