<view class="wrong-book-page">

<view class="header-bar" wx:if="{{hasData}}">
  <text class="count-text">共 {{wrongList.length}} 题</text>
  
  <picker bindchange="onFilterChange" value="{{filterIndex}}" range="{{filterOptions}}">
    <view class="filter-picker">
      <text>{{filterOptions[filterIndex]}}</text>
      <text class="picker-arrow">▼</text>
    </view>
  </picker>

  <view class="clear-btn" bindtap="clearAll">
    <text class="icon-trash">🗑️</text> 一键清空
  </view>
</view>

<scroll-view scroll-y="true" class="list-container" bindtap="recoverSwipe">
  
  <block wx:if="{{wrongList.length > 0}}">
    <view class="list-item-wrap" wx:for="{{wrongList}}" wx:key="id">
      
      <view class="wrong-card"
            bindtouchstart="touchS" bindtouchmove="touchM" bindtouchend="touchE" data-index="{{index}}"
            style="transform: translateX({{item.offsetX || 0}}rpx); transition: {{isMoving ? 'none' : 'transform 0.3s'}};">
        
        <view class="remove-btn" catchtap="removeItem" data-index="{{index}}">✕</view>
        
        <view class="item-header">
          <view class="item-name">
          {{item.name}}
          <text class="error-badge level-high" wx:if="{{item.errorCount >= 3}}">高频易错(错{{item.errorCount}}次)</text>
          <text class="error-badge level-mid" wx:elif="{{item.errorCount == 2}}">重蹈覆辙(错2次)</text>
        </view>
        </view>
        
        <view class="card-divider"></view>
        
        <view class="item-answers">
          <text class="wrong-ans">{{item.errorCount > 1 ? '你最近选了' : '你的选择'}}：{{item.userSelect}}</text>
          
          <text class="correct-ans">正确答案：{{item.correctAnswer}}</text>
        </view>
        
      </view>

      <view class="delete-action" catchtap="removeItem" data-index="{{index}}">删除</view>
    </view>
  </block>

  <view class="empty-state" wx:else>
    <icon type="info" size="64" color="#ccc"></icon>
    <text class="empty-text">暂无对应频次的错题记录~</text>
  </view>

</scroll-view>

</view>