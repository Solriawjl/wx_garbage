/* pages/user/wrongBook.wxss */
.wrong-book-page {
  min-height: 100vh;
  background-color: #f5f7fa; 
  display: flex;
  flex-direction: column;
}

/* --- 顶部操作栏 --- */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.count-text {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.clear-btn {
  font-size: 26rpx;
  color: #F44336; /* 红色警示文字 */
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #ffebee;
  border-radius: 30rpx;
  transition: transform 0.1s;
}

.clear-btn:active {
  transform: scale(0.95);
}

.icon-trash {
  margin-right: 8rpx;
  font-size: 26rpx;
}

/* --- 列表容器 --- */
.list-container {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* --- 错题卡片 --- */
.wrong-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.remove-btn {
  font-size: 32rpx;
  color: #ccc;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: consolas;
}

.card-divider {
  width: 100%;
  height: 2rpx;
  border-bottom: 2rpx dashed #eeeeee;
  margin-bottom: 25rpx;
}

.item-answers {
  display: flex;
  flex-direction: column;
}

.answer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.answer-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #888;
}

/* 重点：划掉错误答案，高亮正确答案 */
.wrong-ans {
  font-size: 28rpx;
  color: #b2b2b2;
  text-decoration: line-through; /* 中划线 */
}

.correct-ans {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50; /* 采用正确的绿色，增强记忆 */
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 250rpx;
}

.empty-text {
  margin-top: 40rpx;
  font-size: 30rpx;
  color: #888;
}