/* pages/user/wrongBook.wxss */
.wrong-book-page {
  min-height: 100vh;
  background-color: #f5f7fa; 
  display: flex;
  flex-direction: column;
}

/* ==========================================
   顶部操作栏与筛选
========================================== */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.count-text {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.clear-btn {
  font-size: 26rpx;
  color: #F44336; 
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #ffebee;
  border-radius: 30rpx;
  transition: transform 0.1s;
}

.clear-btn:active {
  transform: scale(0.95);
}

.filter-picker {
  display: flex;
  align-items: center;
  font-size: 28rpx;
  color: #333;
  background-color: #f0f2f5;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.picker-arrow {
  font-size: 20rpx;
  margin-left: 10rpx;
  color: #888;
}

/* ==========================================
   列表容器与卡片包裹
========================================== */
.list-container {
  flex: 1;
  padding: 20rpx 0;
  box-sizing: border-box;
}

/* 核心：包裹着卡片和底部删除按钮的容器 */
.list-item-wrap {
  position: relative;
  width: 92%;
  margin: 0 auto 30rpx auto;
  border-radius: 20rpx;
  overflow: hidden; 
  background-color: #FF5252; /* 给底层垫上一层红色，配合滑动 */
}

/* 错题卡片本身（上层） */
.wrong-card {
  position: relative;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 40rpx;
  box-shadow: 0 6rpx 20rpx rgba(0,0,0,0.04);
  z-index: 2; 
  box-sizing: border-box;
  width: 100%;
}

/* 底层露出的西瓜红删除按钮（下层） */
.delete-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #FF5252; 
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  z-index: 1;
}

/* ==========================================
   卡片内部细节
========================================== */
.item-header {
  margin-bottom: 20rpx;
  padding-right: 20rpx; 
}

.item-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.error-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  margin-left: 15rpx;
  font-weight: normal;
  vertical-align: middle;
}

.level-high { background-color: #ffebee; color: #F44336; }
.level-mid { background-color: #fff3e0; color: #FF9800; }

.item-answers {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 20rpx 0;
  border-top: 2rpx dashed #f0f0f0;
}

.wrong-ans {
  font-size: 28rpx;
  color: #F44336; 
}

.correct-ans {
  font-size: 28rpx;
  color: #4CAF50; 
  font-weight: bold;
}

/* 🚀 修复点：完美的底部 Flex 布局，防止时间太长挤爆按钮 */
.card-footer {
  margin-top: 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
}

.error-time {
  font-size: 24rpx;
  color: #aaa;
  flex: 1; /* 占据左侧所有的剩余空间 */
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis; /* 时间超长时显示省略号 */
  margin-right: 20rpx;
}

/* =========================================
   🚀 新增：已掌握 / 消灭错题的变身样式
========================================= */

/* 1. 已消灭状态的卡片：实色浅灰背景，坚决不能透明漏底！ */
.resolved-card {
  background-color: #F8F9FA !important; 
}

/* 2. 弱化卡片内文字颜色，模拟已失效/已掌握的视觉感 */
.resolved-card .item-name { color: #999; }
.resolved-card .wrong-ans { color: #E57373; } 
.resolved-card .correct-ans { color: #81C784; } 

/* 3. 已消灭的专属庆祝印章 */
.resolved-badge {
  font-size: 22rpx;
  color: #FFF;
  background: linear-gradient(135deg, #E0E0E0 0%, #BDBDBD 100%); 
  padding: 4rpx 14rpx;
  border-radius: 10rpx;
  margin-left: 15rpx;
  font-weight: bold;
  vertical-align: middle;
}

/* 4. 我记住了按钮 */
.resolve-btn {
  background: #FF9800;
  color: #FFF;
  font-size: 24rpx;
  padding: 10rpx 26rpx;
  border-radius: 30rpx;
  font-weight: bold;
  box-shadow: 0 4rpx 10rpx rgba(255, 152, 0, 0.3);
  flex-shrink: 0; /* 🚀 防止按钮被左边挤压变形 */
}

.resolve-btn:active {
  transform: scale(0.95);
  background: #F57C00;
}

/* ==========================================
   空状态
========================================== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-img {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 30rpx;
  opacity: 0.8;
}

.empty-desc {
  font-size: 28rpx;
  color: #999;
}