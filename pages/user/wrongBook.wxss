/* pages/user/wrongBook.wxss */
.wrong-book-page {
  min-height: 100vh;
  background-color: #f5f7fa; 
  display: flex;
  flex-direction: column;
}

/* --- 顶部操作栏 --- */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.count-text {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.clear-btn {
  font-size: 26rpx;
  color: #F44336; /* 红色警示文字 */
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #ffebee;
  border-radius: 30rpx;
  transition: transform 0.1s;
}

.clear-btn:active {
  transform: scale(0.95);
}

.icon-trash {
  margin-right: 8rpx;
  font-size: 26rpx;
}

/* --- 列表容器 --- */
.list-container {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* --- 错题卡片 --- */
.wrong-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03);
}

.item-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.item-name {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.remove-btn {
  font-size: 32rpx;
  color: #ccc;
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: consolas;
}

.card-divider {
  width: 100%;
  height: 2rpx;
  border-bottom: 2rpx dashed #eeeeee;
  margin-bottom: 25rpx;
}

.item-answers {
  display: flex;
  flex-direction: column;
}

.answer-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 15rpx;
}

.answer-row:last-child {
  margin-bottom: 0;
}

.label {
  font-size: 28rpx;
  color: #888;
}

/* 重点：划掉错误答案，高亮正确答案 */
.wrong-ans {
  font-size: 28rpx;
  color: #b2b2b2;
  text-decoration: line-through; /* 中划线 */
}

.correct-ans {
  font-size: 32rpx;
  font-weight: bold;
  color: #4CAF50; /* 采用正确的绿色，增强记忆 */
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 250rpx;
}

.empty-text {
  margin-top: 40rpx;
  font-size: 30rpx;
  color: #888;
}

/* --- 左滑删除与无边框溢出核心样式 --- */

/* 1. 外层包裹器：接管阴影，消除滑动时的裁切感 */
.list-item-wrap {
  position: relative;
  width: 100%;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  background-color: #ffffff; /* 保持白色底 */
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); 
}

/* 2. 可滑动的卡片本体：覆盖原有边距和阴影 */
.wrong-card {
  margin-bottom: 0 !important; 
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 2; 
  background-color: #ffffff; 
  border-radius: 20rpx;
  box-shadow: none !important; /* 原本的阴影交由父级 */
}

/* 3. 右上角独立删除 X */
.remove-btn {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  color: #d8d8d8; 
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: consolas;
  font-size: 32rpx;
  z-index: 10;
}

/* 4. 底层露出的西瓜红删除按钮 */
.delete-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #FF5252; 
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  z-index: 1;
  border-top-right-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}