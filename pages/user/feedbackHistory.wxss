/* pages/user/feedbackHistory.wxss */
.feedback-page {
  min-height: 100vh;
  background-color: #f5f7fa; 
  display: flex;
  flex-direction: column;
}

/* --- 顶部操作与筛选栏 --- */
.header-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.count-text {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.clear-btn {
  font-size: 26rpx;
  color: #F44336; 
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #ffebee;
  border-radius: 30rpx;
  transition: transform 0.1s;
}

.clear-btn:active {
  transform: scale(0.95);
}

.icon-trash {
  margin-right: 6rpx;
  font-size: 28rpx;
}

/* --- 🚀 新增：中间下拉筛选器样式 --- */
.filter-picker {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  border: 2rpx solid #eeeeee;
  transition: all 0.2s;
}

.filter-picker:active {
  background-color: #e0e0e0;
}

.picker-arrow {
  font-size: 18rpx;
  margin-left: 10rpx;
  color: #888;
}

/* --- 列表容器 --- */
.list-container {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* --- 滑动卡片外层包裹 --- */
.list-item-wrap {
  position: relative;
  width: 100%;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  background-color: #ffffff; 
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); 
}

/* 反馈卡片本体 */
.feedback-card {
  margin-bottom: 0 !important; 
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 2; 
  background-color: #ffffff; 
  border-radius: 20rpx;
  padding: 30rpx 40rpx;
  box-shadow: none !important; 
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx dashed #eee;
}

.type-tag {
  font-size: 24rpx;
  padding: 6rpx 16rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

.tag-text {
  background-color: #e3f2fd;
  color: #1976D2;
}

.tag-image {
  background-color: #e8f5e9;
  color: #388E3C;
}

.status-tag {
  font-size: 24rpx;
  font-weight: bold;
}

.status-pending { color: #FF9800; }
.status-adopted { color: #4CAF50; }
.status-rejected { color: #F44336; }

/* 卡片主体内容 */
.card-body {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.feedback-img {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  background-color: #f5f5f5;
  flex-shrink: 0;
}

.source-info {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.source-info.no-margin {
  margin-bottom: 0;
}

.label {
  font-size: 24rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.value {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.error-text {
  color: #F44336;
}

.highlight {
  color: #1976D2;
}

.content-row {
  background-color: #f9f9f9;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

/* 管理员回复 */
.admin-reply-box {
  background-color: #e8f5e9;
  padding: 16rpx 20rpx;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  display: flex;
  flex-direction: column;
}

.reply-label {
  font-size: 24rpx;
  color: #388E3C;
  font-weight: bold;
  margin-bottom: 6rpx;
}

.reply-text {
  font-size: 26rpx;
  color: #2e7d32;
  line-height: 1.4;
}

/* --- 🚀 环保币奖励提示条样式 --- */
.reward-row {
  margin-bottom: 20rpx;
  padding: 12rpx 20rpx;
  background: rgba(255, 152, 0, 0.1); /* 淡金色的背景 */
  border-radius: 12rpx;
  display: flex;
  align-items: center;
}

.reward-text {
  font-size: 26rpx;
  color: #FF9800; /* 金橙色高亮文字 */
  font-weight: bold;
}

/* 底部时间 */
.card-footer {
  text-align: right;
}

.date-text {
  font-size: 22rpx;
  color: #aaa;
}

/* --- 右上角独立删除 X --- */
.remove-btn {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  color: #d8d8d8; 
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: consolas;
  font-size: 32rpx;
  z-index: 10;
}

/* --- 底层露出的西瓜红删除按钮 --- */
.delete-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #FF5252; 
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  z-index: 1;
  border-top-right-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}