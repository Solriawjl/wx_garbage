/* pages/user/index.wxss */
.user-page {
  min-height: 100vh;
  background-color: #f5f7fa; /* 极浅的灰底色 */
}

/* --- 顶部渐变背景 --- */
.user-header {
  height: 360rpx;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  padding: 60rpx 40rpx 0;
  box-sizing: border-box;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar-btn {
  padding: 0;
  margin: 0;
  margin-right: 30rpx;
  width: 130rpx !important;
  height: 130rpx !important;
  border-radius: 50%;
  background-color: transparent; /* 去除按钮灰底 */
}

/* 去除微信默认按钮的黑色边框 */
.avatar-btn::after {
  border: none;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  background-color: #eee;
  display: block; /* 解决图片底部的默认空隙 */
}

.nickname-input {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 15rpx;
  min-height: 50rpx; /* 保证没字的时候也能点 */
}

.info-text {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 15rpx;
}

.title-tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  align-self: flex-start;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

/* --- 数据看板 (破框悬浮设计) --- */
.data-board {
  width: 90%;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin: -80rpx auto 40rpx; /* 负 margin 让其悬浮在绿色背景上 */
  display: flex;
  justify-content: space-evenly;
  align-items: center;
  padding: 40rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
  position: relative;
  z-index: 2;
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}

.data-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.data-label {
  font-size: 26rpx;
  color: #888;
}

.data-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #f0f0f0;
}

/* --- 功能列表菜单 --- */
.menu-list {
  width: 90%;
  margin: 0 auto 30rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 110rpx;
  border-bottom: 2rpx solid #f9f9f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-family: consolas; /* 让箭头看起来更整齐 */
}

/* --- 退出登录按钮 --- */
.logout-btn {
  width: 90%;
  margin: 40rpx auto 60rpx;
  height: 100rpx;
  background-color: #ffffff;
  color: #F44336;
  font-size: 34rpx;
  font-weight: bold;
  display: flex;
  justify-content: center;
  align-items: center;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03);
  transition: background-color 0.2s;
}

.logout-btn:active {
  background-color: #f9f9f9;
}

/* =========================================
   环保星商城超级入口样式
   ========================================= */
   .mall-entry-card {
    width: 90%;
    margin: 0 auto 30rpx;
    /* 充满诱惑力的渐变黄橙色 */
    background: linear-gradient(135deg, #FFF8E1 0%, #FFECB3 100%); 
    border-radius: 20rpx;
    padding: 30rpx;
    display: flex;
    justify-content: space-between;
    align-items: center;
    box-shadow: 0 8rpx 20rpx rgba(255, 152, 0, 0.15);
    border: 2rpx solid #FFE082;
    transition: transform 0.1s;
  }
  
  .mall-entry-card:active {
    transform: scale(0.98); /* 点击反馈 */
  }
  
  .mall-entry-left {
    display: flex;
    align-items: center;
  }
  
  .mall-icon {
    width: 70rpx;
    height: 70rpx;
    margin-right: 20rpx;
    /* 加个轻微的上下浮动动画，吸引点击 */
    animation: floatIcon 2s ease-in-out infinite; 
  }
  
  @keyframes floatIcon {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6rpx); }
  }
  
  .mall-text {
    display: flex;
    flex-direction: column;
  }
  
  .mall-title {
    font-size: 32rpx;
    font-weight: 900;
    color: #E65100;
    margin-bottom: 6rpx;
  }
  
  .mall-desc {
    font-size: 22rpx;
    color: #F57F17;
    font-weight: bold;
  }
  
  .mall-entry-right {
    display: flex;
    align-items: center;
  }
  
  .mall-go {
    font-size: 26rpx;
    color: #fff;
    background-color: #FF9800;
    padding: 8rpx 24rpx;
    border-radius: 30rpx;
    font-weight: bold;
    margin-right: 10rpx;
    box-shadow: 0 4rpx 10rpx rgba(255, 152, 0, 0.4);
  }
  
  .mall-arrow {
    color: #FF9800;
    font-family: consolas;
    font-weight: bold;
  }