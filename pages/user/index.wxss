/* pages/user/index.wxss */
.user-page {
  min-height: 100vh;
  background-color: #f5f7fa; /* 极浅的灰底色 */
}

/* --- 顶部渐变背景 --- */
.user-header {
  height: 360rpx;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  padding: 60rpx 40rpx 0;
  box-sizing: border-box;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.4);
  margin-right: 30rpx;
  background-color: #eee;
}

.info-text {
  display: flex;
  flex-direction: column;
}

.nickname {
  font-size: 40rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 15rpx;
}

.title-tag {
  background-color: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 24rpx;
  padding: 6rpx 20rpx;
  border-radius: 30rpx;
  align-self: flex-start;
  border: 2rpx solid rgba(255, 255, 255, 0.5);
}

/* --- 数据看板 (破框悬浮设计) --- */
.data-board {
  width: 90%;
  background-color: #ffffff;
  border-radius: 20rpx;
  margin: -80rpx auto 40rpx; /* 负 margin 让其悬浮在绿色背景上 */
  display: flex;
  justify-content: space-evenly;
  align-items: center;
  padding: 40rpx 0;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
  position: relative;
  z-index: 2;
}

.data-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 30%;
}

.data-num {
  font-size: 44rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.data-label {
  font-size: 26rpx;
  color: #888;
}

.data-divider {
  width: 2rpx;
  height: 60rpx;
  background-color: #f0f0f0;
}

/* --- 功能列表菜单 --- */
.menu-list {
  width: 90%;
  margin: 0 auto 30rpx;
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.02);
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  height: 110rpx;
  border-bottom: 2rpx solid #f9f9f9;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-left {
  display: flex;
  align-items: center;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.menu-text {
  font-size: 30rpx;
  color: #333;
}

.menu-arrow {
  color: #ccc;
  font-family: consolas; /* 让箭头看起来更整齐 */
}