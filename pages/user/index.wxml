<view class="user-page">

<view class="user-header">
  <block wx:if="{{isLoggedIn}}">
    <view class="user-info">
      <button class="avatar-btn" open-type="chooseAvatar" bind:chooseavatar="onChooseAvatar">
        <image class="avatar" src="{{avatarUrl}}" mode="aspectFill"></image>
      </button>
      
      <view class="info-text">
        <input type="nickname" class="nickname-input" placeholder="点击设置昵称" placeholder-style="color: rgba(255,255,255,0.7);" value="{{nickname}}" bindblur="onNicknameBlur" />
        
        <view class="tag-group">
          <view class="title-tag" style="{{role === 'teacher' ? 'background: #00897B;' : ''}}">{{role === 'teacher' ? '指导老师' : userTitle}}</view>
          
          <picker mode="multiSelector" bindchange="onClassPickerChange" bindcolumnchange="onClassPickerColumnChange" value="{{pickerIndex}}" range="{{pickerArray}}">
            <view class="class-tag">📍 {{fullClassName}} ✎</view>
          </picker>
        </view>
      </view>
    </view>
  </block>

  <block wx:else>
    <view class="user-info" bindtap="handleUserLogin">
      <view class="avatar-btn">
        <image class="avatar" src="https://images-1408449839.cos.ap-chengdu.myqcloud.com/images/user/head.png" mode="aspectFill"></image>
      </view>
      <view class="info-text">
        <view class="login-text" style="font-size: 34rpx; font-weight: bold; color: #fff; margin-bottom: 10rpx;">点击授权登录</view>
        <view class="title-tag" style="background: rgba(255,255,255,0.2);">未登录</view>
      </view>
    </view>
  </block>
</view>

<block wx:if="{{role === 'student'}}">
  <view class="data-board">
    <view class="data-item">
      <text class="data-num">{{isLoggedIn ? totalScore : '-'}}</text>
      <text class="data-label">累计环保星</text>
    </view>

    <view class="data-divider"></view>
    
    <view class="data-item">
      <text class="data-num">{{isLoggedIn ? ecoCoin : '-'}}</text>
      <text class="data-label">可用小红花</text>
    </view>
  
    <view class="data-divider"></view>
    
    <view class="data-item">
      <text class="data-num">{{isLoggedIn ? recognizeCount : '-'}}</text>
      <text class="data-label">探索次数</text>
    </view>
    
    <view class="data-divider"></view>
    
    <view class="data-item">
      <text class="data-num">{{isLoggedIn ? challengeCount : '-'}}</text>
      <text class="data-label">挑战次数</text>
    </view>
  </view>
</block>

<block wx:if="{{role === 'student'}}">
  <view class="mall-entry-card" bindtap="goToMall">
    <view class="mall-entry-left">
      <image class="mall-icon" src="https://images-1408449839.cos.ap-chengdu.myqcloud.com/images/user/red_flower.png" mode="aspectFit"></image>
      <view class="mall-text">
        <text class="mall-title">小红花兑换商城</text>
        <text class="mall-desc">用小红花换取专属奖励！</text>
      </view>
    </view>
    <view class="mall-entry-right">
      <text class="mall-go">去兑换</text>
      <text class="mall-arrow">></text>
    </view>
  </view>

  <view class="menu-list">
    <view class="menu-item" bindtap="goToReport">
      <view class="menu-left">
        <text class="menu-icon">📊</text>
        <text class="menu-text" style="font-weight: bold; color: #4CAF50;">我的环保成长报告</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToHistory" data-type="recognize">
      <view class="menu-left">
        <text class="menu-icon">🔍</text>
        <text class="menu-text">我的探索日记</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToHistory" data-type="challenge">
      <view class="menu-left">
        <text class="menu-icon">🏆</text>
        <text class="menu-text">挑战记录</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToWrongBook">
      <view class="menu-left">
        <text class="menu-icon">📓</text>
        <text class="menu-text">打怪错题本</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToFeedbackHistory">
      <view class="menu-left">
        <text class="menu-icon">✉️</text>
        <text class="menu-text">我的反馈</text>
      </view>
      <text class="menu-arrow">></text>
    </view>
  </view>
</block>

<block wx:elif="{{role === 'teacher'}}">
  <view class="menu-list" style="margin-top: 30rpx;">
    <view class="menu-item" bindtap="openNoticeModal">
      <view class="menu-left">
        <text class="menu-icon">📢</text>
        <text class="menu-text" style="font-weight: bold; color: #E6A23C;">发布班级通知</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToTeacherDashboard">
      <view class="menu-left">
        <text class="menu-icon">📈</text>
        <text class="menu-text">班级学情大盘</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToTeacherVerify">
      <view class="menu-left">
        <text class="menu-icon">🎁</text>
        <text class="menu-text">奖品核销中心</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-item" bindtap="goToTeacherMallManage">
      <view class="menu-left">
        <text class="menu-icon">🏪</text>
        <text class="menu-text">小红花商城库房</text>
      </view>
      <text class="menu-arrow">></text>
    </view>

  </view>
</block>

<view class="menu-list">
  <view class="menu-item" bindtap="clearCache">
    <view class="menu-left">
      <text class="menu-icon">🧹</text>
      <text class="menu-text">清除缓存</text>
    </view>
    <text class="menu-arrow">></text>
  </view>
  
  <view class="menu-item" bindtap="showAbout">
    <view class="menu-left">
      <text class="menu-icon">ℹ️</text>
      <text class="menu-text">关于我们</text>
    </view>
    <text class="menu-arrow">></text>
  </view>
</view>

<view class="logout-btn" bindtap="logout" wx:if="{{isLoggedIn}}">退出登录</view>
<view class="modal-mask" wx:if="{{showNoticeModal}}" catchtouchmove="true">
  <view class="modal-content">
    <view class="modal-header">
      <text>发布班级通知</text>
      <view class="close-btn" bindtap="closeNoticeModal">✕</view>
    </view>
    
    <view class="modal-body">
      <view class="form-group">
        <text class="form-label">接收对象：</text>
        <picker bindchange="onTargetChange" value="{{targetIndex}}" range="{{targetList}}" range-key="name">
          <view class="picker-box">
            <text class="{{targetIndex == 0 ? 'text-all' : 'text-single'}}">{{targetList[targetIndex].name}}</text>
            <text class="picker-arrow">▼</text>
          </view>
        </picker>
      </view>

      <view class="form-row-2">
        <view class="form-group half">
          <text class="form-label">通知类型：</text>
          <picker bindchange="onTypeChange" value="{{typeIndex}}" range="{{typeList}}">
            <view class="picker-box mini-picker">{{typeList[typeIndex]}} <text class="picker-arrow">▼</text></view>
          </picker>
        </view>
        <view class="form-group half">
          <text class="form-label">生效时长：</text>
          <picker bindchange="onDurationChange" value="{{durationIndex}}" range="{{durationList}}">
            <view class="picker-box mini-picker">{{durationList[durationIndex]}} <text class="picker-arrow">▼</text></view>
          </picker>
        </view>
      </view>
      
      <view class="form-group">
        <text class="form-label">通知内容：</text>
        <textarea class="notice-input" placeholder="请输入你要下发的通知内容..." bindinput="onNoticeInput" value="{{noticeContent}}" fixed="true" cursor-spacing="100"></textarea>
      </view>
    </view>
    
    <view class="modal-footer">
      <view class="btn-cancel" bindtap="closeNoticeModal">取消</view>
      <view class="btn-confirm {{noticeContent.length == 0 ? 'btn-disabled' : ''}}" bindtap="submitNotice">立即发布</view>
    </view>
  </view>
</view>
</view>