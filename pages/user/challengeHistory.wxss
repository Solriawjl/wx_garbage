/* pages/user/challengeHistory.wxss */
.history-page {
  min-height: 100vh;
  background-color: #f5f7fa; 
  display: flex;
  flex-direction: column;
}

/* --- 筛选栏 --- */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx 40rpx;
  background-color: #ffffff;
  border-bottom: 2rpx solid #eee;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.02);
  z-index: 10;
}

.filter-text {
  font-size: 28rpx;
  color: #666;
  font-weight: bold;
}

.filter-btn {
  font-size: 28rpx;
  color: #4CAF50;
  display: flex;
  align-items: center;
}

.icon-filter {
  font-size: 24rpx;
  margin-left: 8rpx;
  font-family: Arial, sans-serif;
}

/* --- 列表容器 --- */
.list-container {
  flex: 1;
  padding: 30rpx;
  box-sizing: border-box;
}

/* --- 挑战摘要卡片 --- */
.challenge-card {
  background-color: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx 40rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03);
  transition: transform 0.1s;
}

.challenge-card:active {
  transform: scale(0.98);
}

/* 卡片上半部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end; /* 让底部对齐 */
  margin-bottom: 25rpx;
}

.score-box {
  display: flex;
  align-items: baseline;
}

.score-label {
  font-size: 26rpx;
  color: #888;
  margin-right: 15rpx;
}

.score-num {
  font-size: 50rpx;
  font-weight: bold;
  color: #ffb300; /* 抢眼的橙黄色环保星 */
  font-family: 'Courier New', Courier, monospace; /* 让数字看起来更有科技感 */
}

/* 称号标签 */
.title-tag {
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

/* 称号的动态颜色 */
.level-4 { background-color: #fff3e0; color: #ff9800; border: 2rpx solid #ffe0b2; } /* 王者：橙金 */
.level-3 { background-color: #e3efff; color: #2196F3; border: 2rpx solid #bbdefb; } /* 达人：亮蓝 */
.level-2 { background-color: #e8f5e9; color: #4CAF50; border: 2rpx solid #c8e6c9; } /* 卫士：生机绿 */
.level-1 { background-color: #f5f5f5; color: #8D6E63; border: 2rpx solid #d7ccc8; } /* 新手：大地色 */

/* 分割线 */
.card-divider {
  width: 100%;
  height: 2rpx;
  border-bottom: 2rpx dashed #eeeeee;
  margin-bottom: 25rpx;
}

/* 卡片下半部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.stat-box {
  font-size: 26rpx;
  color: #666;
}

.stat-val {
  font-weight: bold;
  color: #333;
  font-size: 30rpx;
}

.stat-val.perfect {
  color: #4CAF50; /* 满分绿字表扬 */
}

.date-box {
  display: flex;
  align-items: center;
}

.date-text {
  font-size: 24rpx;
  color: #aaa;
  margin-right: 10rpx;
}

.arrow {
  color: #ccc;
  font-family: consolas;
  font-size: 28rpx;
}

/* --- 空状态 --- */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 200rpx;
}

.empty-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #999;
}

/* --- 一键清空与左滑删除核心样式 --- */

/* 覆盖顶栏样式 */
.clear-btn {
  font-size: 26rpx;
  color: #F44336;
  display: flex;
  align-items: center;
  padding: 10rpx 20rpx;
  background-color: #ffebee;
  border-radius: 30rpx;
  transition: transform 0.1s;
}
.clear-btn:active { transform: scale(0.95); }
.icon-trash { margin-right: 8rpx; font-size: 26rpx; }

/* 1. 外层包裹器：接管阴影和整体间距 */
.list-item-wrap {
  position: relative;
  width: 100%;
  margin-bottom: 30rpx;
  border-radius: 20rpx;
  background-color: #ffffff;
  box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); 
}

/* 2. 可滑动的卡片本体 */
.challenge-card {
  margin-bottom: 0 !important; 
  width: 100%;
  box-sizing: border-box;
  position: relative;
  z-index: 2; 
  background-color: #ffffff; 
  border-radius: 20rpx;
  box-shadow: none !important; 
}

/* 3. 右上角独立删除 X */
.remove-btn {
  position: absolute;
  top: 15rpx;
  right: 15rpx;
  color: #d8d8d8; 
  width: 50rpx;
  height: 50rpx;
  display: flex;
  justify-content: center;
  align-items: center;
  font-family: consolas;
  font-size: 32rpx;
  z-index: 10;
}

/* 4. 底层露出的删除按钮 (西瓜红) */
.delete-action {
  position: absolute;
  right: 0;
  top: 0;
  bottom: 0;
  width: 140rpx;
  background-color: #FF5252;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: bold;
  z-index: 1;
  border-top-right-radius: 20rpx;
  border-bottom-right-radius: 20rpx;
}

/* --- 🚀 新增：中间下拉筛选器样式 --- */
.filter-picker {
  display: flex;
  align-items: center;
  background-color: #f5f5f5;
  padding: 10rpx 28rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #333;
  font-weight: bold;
  border: 2rpx solid #eeeeee;
  transition: all 0.2s;
}

.filter-picker:active {
  background-color: #e0e0e0;
}

.picker-arrow {
  font-size: 18rpx;
  margin-left: 10rpx;
  color: #888;
}

/* 标签容器组 */
.title-tags {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

/* 模式专属标签 */
.mode-tag {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

/* 浅紫色经典模式 */
.mode-classic {
  background-color: #f3e5f5; 
  color: #9c27b0; 
  border: 2rpx solid #e1bee7;
}

/* 浅橙色限时模式 */
.mode-timed {
  background-color: #fff3e0;
  color: #ef6c00; 
  border: 2rpx solid #ffe0b2;
}