/* 页面底层背景色，非常淡的绿色 */
page {
  background-color: #f7fbf2;
}

.index-container {
  padding: 20rpx 30rpx 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  box-sizing: border-box;
}

/* 1. 精致的用户欢迎头部 */
.user-header {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 35rpx;
  padding: 0 10rpx;
}

.avatar-circle {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #dcedc8, #8bc34a);
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 44rpx; 
  margin-right: 24rpx;
  box-shadow: 0 6rpx 16rpx rgba(139, 195, 74, 0.3);
}

.avatar-image {
  width: 90rpx;
  height: 90rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
  border: 4rpx solid #ffffff;
  box-sizing: border-box;
}

.greeting-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #2c3e50;
  margin-bottom: 6rpx;
  letter-spacing: 1rpx;
  max-width: 450rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.greeting-box {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.greeting-desc {
  font-size: 24rpx;
  color: #7f8c8d;
}

/* 2. 搜索栏 (更圆润轻薄) */
.search-bar {
  width: 100%;
  background-color: #ffffff;
  height: 90rpx;
  border-radius: 45rpx;
  display: flex;
  align-items: center;
  padding: 0 40rpx;
  box-shadow: 0 6rpx 16rpx rgba(0,0,0,0.03);
  margin-bottom: 40rpx;
  box-sizing: border-box;
}
.search-text {
  color: #a5b1c2;
  font-size: 28rpx;
  margin-left: 20rpx;
}

/* 3. 绝对核心：AI 大卡片 */
.ai-action-card {
  width: 100%;
  background: linear-gradient(135deg, #a8e063, #56ab2f);
  border-radius: 40rpx;
  padding: 70rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  box-shadow: 0 16rpx 40rpx rgba(86, 171, 47, 0.35); 
  margin-bottom: 40rpx;
  transition: transform 0.2s;
}
.ai-action-card:active {
  transform: scale(0.97);
}
.ai-bg-circle {
  position: absolute;
  top: -60rpx;
  right: -60rpx;
  width: 250rpx;
  height: 250rpx;
  background-color: rgba(255, 255, 255, 0.15);
  border-radius: 50%;
}
.ai-camera-icon {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 30rpx;
  z-index: 1;
}
.ai-text-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  z-index: 1;
  color: #ffffff;
  margin-bottom: 40rpx;
}
.ai-title {
  font-size: 48rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
  margin-bottom: 12rpx;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}
.ai-subtitle {
  font-size: 28rpx;
  opacity: 0.9;
}
.ai-btn {
  background-color: #ffffff;
  color: #56ab2f;
  font-weight: 800;
  font-size: 34rpx;
  padding: 24rpx 70rpx;
  border-radius: 50rpx;
  z-index: 1;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.15);
}

/* 4. 每日小知识 (独立胶囊外观) */
.daily-tip-box {
  width: 100%;
  background-color: #ffffff;
  height: 100rpx;
  border-radius: 20rpx;
  padding: 0 30rpx;
  box-sizing: border-box;
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.03);
}
.tip-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}
.tip-swiper {
  flex: 1;
  height: 100%;
}
.tip-swiper-item {
  display: flex;
  align-items: center;
  height: 100%;
}
.tip-text {
  font-size: 28rpx;
  color: #444;
  font-weight: 500;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  width: 100%;
}
.tip-arrow {
  color: #ccc;
  font-weight: bold;
  margin-left: 15rpx;
  font-size: 30rpx;
}

/* 5. 游戏化互动：知识挑战大横幅 */
.challenge-banner {
  width: 100%;
  background: linear-gradient(135deg, #fff3e0, #ffe0b2);
  border-radius: 24rpx;
  padding: 35rpx 40rpx;
  box-sizing: border-box;
  display: flex;
  justify-content: space-between;
  align-items: center;
  box-shadow: 0 8rpx 20rpx rgba(255, 152, 0, 0.15);
}
.challenge-text-area {
  display: flex;
  flex-direction: column;
}
.challenge-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #e65100;
  margin-bottom: 10rpx;
}
.challenge-desc {
  font-size: 24rpx;
  color: #ef6c00;
}
.challenge-go-btn {
  background-color: #ff9800;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: bold;
  padding: 16rpx 36rpx;
  border-radius: 40rpx;
  box-shadow: 0 6rpx 12rpx rgba(255, 152, 0, 0.3);
}

/* ==========================================
   🚀 升级版：首页动态通知栏样式
   ========================================== */
.notice-bar {
  display: flex;
  align-items: center;
  background-color: #fdf6ec; 
  border-radius: 20rpx;
  padding: 0 25rpx;
  height: 80rpx;
  width: 100%;
  margin-bottom: 30rpx; 
  box-shadow: 0 4rpx 10rpx rgba(255, 152, 0, 0.1);
  box-sizing: border-box;
}
.notice-icon-wrap { font-size: 34rpx; margin-right: 15rpx; }
.notice-swiper { flex: 1; height: 100%; }
.notice-text { display: flex; align-items: center; height: 100%; font-size: 26rpx; color: #e6a23c; overflow: hidden; width: 100%; }
.notice-tag { 
  display: inline-block; /* 强制作为整块渲染 */
  vertical-align: middle;
  font-size: 20rpx; 
  padding: 4rpx 12rpx; 
  border-radius: 10rpx; 
  margin-right: 12rpx; 
  color: #fff; 
  font-weight: bold; 
  flex-shrink: 0; 
  white-space: nowrap; /* 绝对核心：禁止内部文本换行 */
  line-height: 1.4;
}
.tag-reward { background-color: #f56c6c; } 
.tag-teacher { background-color: #409EFF; } 
.notice-content { flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.empty-notice { color: #c0c4cc; font-style: italic; font-size: 24rpx; margin-left: 10rpx; }

.notice-badge { background: #F44336; color: white; font-size: 20rpx; padding: 2rpx 10rpx; border-radius: 20rpx; margin-right: 15rpx; font-weight: bold;}
.notice-arrow { color: #e6a23c; font-weight: bold; font-family: consolas;}

/* --- 🚀 消息列表弹窗 --- */
.notice-modal-mask { position: fixed; top: 0; left: 0; right: 0; bottom: 0; background: rgba(0,0,0,0.6); z-index: 9999; display: flex; justify-content: center; align-items: flex-end; }
.notice-list-box { width: 100%; height: 75vh; background: #f5f7fa; border-radius: 40rpx 40rpx 0 0; display: flex; flex-direction: column; animation: slideUp 0.3s ease-out; }
@keyframes slideUp { from { transform: translateY(100%); } to { transform: translateY(0); } }

.nl-header { display: flex; justify-content: space-between; padding: 35rpx 40rpx; background: #fff; border-radius: 40rpx 40rpx 0 0; font-size: 34rpx; font-weight: bold; }
.nl-close { color: #999; font-size: 36rpx; padding: 0 10rpx; }
.nl-scroll { flex: 1; padding: 30rpx; box-sizing: border-box; }

.nl-item { background: #fff; border-radius: 20rpx; padding: 30rpx; margin-bottom: 25rpx; box-shadow: 0 4rpx 15rpx rgba(0,0,0,0.03); }
.nl-item-header { margin-bottom: 15rpx; }
.nl-item-content { font-size: 28rpx; color: #444; line-height: 1.6; margin-bottom: 20rpx; }
.nl-item-time { font-size: 22rpx; color: #aaa; text-align: right; }

.nl-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; height: 100%; color: #999; font-size: 28rpx; }
.nl-empty icon { margin-bottom: 20rpx; }

.nl-footer { padding: 30rpx; background: #fff; border-top: 1rpx solid #eee; }
.nl-clear-btn { background: #ffebee; color: #F44336; text-align: center; padding: 25rpx 0; border-radius: 40rpx; font-size: 30rpx; font-weight: bold; }
.nl-clear-btn:active { background: #ffcdd2; }