/* pages/index/index.wxss */
.home-page {
  min-height: 100vh;
  background-color: #f5f7fa; 
  display: flex;
  flex-direction: column;
}

/* --- 顶部搜索区 --- */
.search-section {
  background-color: #4CAF50; 
  padding: 20rpx 40rpx 80rpx; /* 底部多留白，为了让大按钮叠在上面 */
}

.search-box {
  background-color: #ffffff;
  height: 80rpx;
  border-radius: 40rpx;
  display: flex;
  align-items: center;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.search-placeholder {
  font-size: 28rpx;
  color: #999;
  margin-left: 20rpx;
}

/* --- 核心 AI 大按钮 (现在它是破框悬浮的视觉中心了) --- */
.core-action-section {
  padding: 0 30rpx;
  margin-top: -50rpx; /* 负边距！让大按钮压在绿底色上 */
  z-index: 2;
  position: relative;
  margin-bottom: 40rpx;
}

.main-btn-card {
  background: linear-gradient(135deg, #66BB6A, #388E3C); 
  border-radius: 30rpx;
  padding: 60rpx 40rpx;
  box-shadow: 0 12rpx 30rpx rgba(76, 175, 80, 0.4); 
  transition: transform 0.1s;
}

.main-btn-card:active {
  transform: scale(0.96); 
}

.btn-content {
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-icon {
  width: 110rpx;
  height: 110rpx;
  margin-right: 40rpx;
  background-color: rgba(255, 255, 255, 0.2); 
  border-radius: 50%;
  padding: 24rpx;
}

.btn-text-group {
  display: flex;
  flex-direction: column;
}

.btn-title {
  font-size: 46rpx;
  font-weight: bold;
  color: #ffffff;
  margin-bottom: 12rpx;
  letter-spacing: 2rpx;
  text-shadow: 0 4rpx 10rpx rgba(0,0,0,0.1);
}

.btn-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* --- 每日贴士 --- */
.tip-section {
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.tip-card {
  background-color: #e8f5e9; 
  border-radius: 16rpx;
  padding: 24rpx 30rpx;
  display: flex;
  align-items: center;
  border: 2rpx solid #c8e6c9;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.02);
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.tip-text {
  flex: 1;
  font-size: 28rpx;
  color: #2e7d32; 
  font-weight: bold;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.tip-arrow {
  font-size: 24rpx;
  color: #66BB6A;
  margin-left: 10rpx;
  font-weight: bold;
}

/* --- 轮播图 (移到底部，恢复正常的视觉边距) --- */
.banner-section {
  margin: 0 30rpx 40rpx;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.05);
}

.banner-swiper {
  height: 400rpx; /* 稍微缩减一点高度，让画面比例更协调 */
  width: 100%;
  background-color: #fff;
  border-radius: 20rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
  border-radius: 20rpx;
}