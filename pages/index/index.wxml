<view class="index-container">
  
  <view class="user-header">
    <image class="avatar-image" wx:if="{{userInfo && userInfo.avatarUrl}}" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
    <view class="avatar-circle" wx:else>🌱</view>

    <view class="greeting-box">
      <text class="greeting-title">{{greetingText}}，{{userInfo.nickName ? userInfo.nickName : '环保小卫士'}}</text>
      <text class="greeting-desc">开启今天的绿色生活</text>
    </view>
  </view>

  <view class="notice-bar" bindtap="openNoticeList">
    <view class="notice-icon-wrap">📢</view>
    
    <block wx:if="{{noticeList.length > 0}}">
      <swiper class="notice-swiper" vertical="true" autoplay="true" circular="true" interval="3500">
        <swiper-item wx:for="{{noticeList}}" wx:key="id">
          <view class="notice-text">
            <text class="notice-tag {{item.type === 'reward' ? 'tag-reward' : 'tag-teacher'}}">{{item.type === 'reward' ? '🏆 奖励通报' : (item.type === 'teacher' ? '老师提醒' : item.type)}}</text>
            <text class="notice-content">{{item.content}}</text>
          </view>
        </swiper-item>
      </swiper>
      <view class="notice-badge">{{noticeList.length}}</view>
    </block>
    
    <block wx:else>
      <view class="notice-text">
        <text class="notice-content empty-notice">暂无新通知，开启美好一天吧~</text>
      </view>
    </block>
    <view class="notice-arrow">></view>
  </view>

  <view class="notice-modal-mask" wx:if="{{showNoticeListModal}}" catchtouchmove="true">
    <view class="notice-list-box">
      <view class="nl-header">
        <text class="nl-title">消息中心</text>
        <view class="nl-close" bindtap="closeNoticeList">✕</view>
      </view>
      
      <scroll-view class="nl-scroll" scroll-y="true">
        <block wx:if="{{noticeList.length > 0}}">
          <view class="nl-item" wx:for="{{noticeList}}" wx:key="id">
            <view class="nl-item-header">
              <text class="notice-tag {{item.type === 'reward' ? 'tag-reward' : 'tag-teacher'}}">{{item.type === 'reward' ? '🏆 系统发奖' :(item.type === 'teacher' ? '老师提醒' : item.type)}}</text>
            </view>
            <view class="nl-item-content">{{item.content}}</view>
            <view class="nl-item-time">{{item.created_at || '最新发布'}}</view> 
          </view>
        </block>
        <block wx:else>
          <view class="nl-empty">
            <icon type="info" size="50" color="#e0e0e0"></icon>
            <text>消息列表空空如也</text>
          </view>
        </block>
      </scroll-view>

      <view class="nl-footer" wx:if="{{noticeList.length > 0}}">
        <view class="nl-clear-btn" bindtap="clearAllNotices">一键标为已读</view>
      </view>
    </view>
  </view>

  <view class="search-bar" bindtap="goToSearch">
    <icon type="search" size="18" color="#999"></icon>
    <text class="search-text">输入你要查询的垃圾名称...</text>
  </view>

  <view class="ai-action-card" bindtap="onTapCamera">
    <view class="ai-bg-circle"></view>
    <image class="ai-camera-icon" src="https://images-1408449839.cos.ap-chengdu.myqcloud.com/images/page_index/camera.png" mode="aspectFit"></image>
    <view class="ai-text-area">
      <text class="ai-title">一键拍照识别</text>
      <text class="ai-subtitle">不知道怎么扔？让 AI 帮帮你</text>
    </view>
    <view class="ai-btn">立即拍照</view>
  </view>

  <view class="daily-tip-box" wx:if="{{carouselTips.length > 0}}">
    <text class="tip-icon">💡</text>
    <swiper class="tip-swiper" vertical="true" autoplay="true" circular="true" interval="3000">
      <block wx:for="{{carouselTips}}" wx:key="id">
        <swiper-item class="tip-swiper-item" catchtap="showTipCard" data-tip="{{item}}">
          <text class="tip-text">{{item.title}}</text>
        </swiper-item>
      </block>
    </swiper>
    <text class="tip-arrow">></text>
  </view>

  <view class="challenge-banner" bindtap="goToChallenge">
    <view class="challenge-text-area">
      <text class="challenge-title">🏆 环保知识大挑战</text>
      <text class="challenge-desc">通关趣味答题，赢取专属称号！</text>
    </view>
    <view class="challenge-go-btn">去挑战</view>
  </view>

  <canvas type="2d" id="aiCanvas" style="width: 224px; height: 224px; position: absolute; left: -9999px;"></canvas>

</view>

<tip-card visible="{{isTipCardVisible}}" tipData="{{currentTipData}}" bind:close="hideTipCard"></tip-card>