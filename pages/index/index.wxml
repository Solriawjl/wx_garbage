<view class="home-page">

<view class="search-section">
  <view class="search-box" bindtap="goToSearch">
    <icon type="search" size="18" color="#999"></icon>
    <text class="search-placeholder">输入你要查询的垃圾名称...</text>
  </view>
</view>

<view class="core-action-section">
  <view class="main-btn-card" bindtap="onTapCamera">
    <view class="btn-content">
      <image class="btn-icon" src="https://images-1408449839.cos.ap-chengdu.myqcloud.com/images/page_index/camera.png" mode="aspectFit"></image>
      <view class="btn-text-group">
        <text class="btn-title">AI 智能识别</text>
        <text class="btn-desc">点击拍照或上传相册图片</text>
      </view>
    </view>
  </view>
</view>

<view class="tip-section">
  <view class="tip-card" bindtap="goToRandomResult">
    <text class="tip-icon">💡</text>
    <text class="tip-text">你知道 [{{dailyItem}}] 属于哪种类型的垃圾吗？</text>
    <text class="tip-arrow">去看看 ></text>
  </view>
</view>

<view class="banner-section">
  <swiper class="banner-swiper" indicator-dots="true" autoplay="true" interval="4000" duration="500" circular="true" indicator-active-color="#4CAF50" indicator-color="rgba(255,255,255,0.6)">
    <swiper-item><image src="https://images-1408449839.cos.ap-chengdu.myqcloud.com/images/page_index/banner/banner1.png" class="banner-img" mode="aspectFill"></image></swiper-item>
    <swiper-item><image src="https://images-1408449839.cos.ap-chengdu.myqcloud.com/images/page_index/banner/banner2.png" class="banner-img" mode="aspectFill"></image></swiper-item>
    <swiper-item><image src="https://images-1408449839.cos.ap-chengdu.myqcloud.com/images/page_index/banner/banner3.png" class="banner-img" mode="aspectFill"></image></swiper-item>
  </swiper>
</view>

</view>